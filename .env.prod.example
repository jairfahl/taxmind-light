# ── Banco ──────────────────────────────────────
POSTGRES_USER=taxmind
POSTGRES_PASSWORD=SUBSTITUIR
POSTGRES_DB=taxmind_db

# ── Backend ─────────────────────────────────────
ANTHROPIC_API_KEY=SUBSTITUIR
VOYAGE_API_KEY=SUBSTITUIR
JWT_SECRET=SUBSTITUIR_COM_HASH_FORTE_64_CHARS
API_INTERNAL_KEY=SUBSTITUIR_UUID
EMBEDDING_MODEL=voyage-3
TOP_K=5
RERANK_TOP_N=20
CHUNK_SIZE=512
CHUNK_OVERLAP=64
LOCKFILE_MODE=WARN
API_CREDIT_LIMIT_USD=3.26

# ── Billing Asaas (sandbox — cobrança desativada nesta fase) ────────────
# ATENÇÃO: se o valor começa com $, usar $$ no .env.prod (escape docker compose)
# Ex: ASAAS_API_KEY=$$aact_... (não $aact_...)
ASAAS_API_KEY=SUBSTITUIR
ASAAS_BASE_URL=https://sandbox.asaas.com/api/v3
ASAAS_WEBHOOK_TOKEN=SUBSTITUIR

# ── ATENÇÃO: VALORES VÁLIDOS ─────────────────────────────────────────────
# LOCKFILE_MODE : WARN | BLOCK          (ENFORCE não é válido — causa ValueError no boot)
# LOG_LEVEL     : DEBUG | INFO | WARNING | ERROR | CRITICAL
# TOP_K         : inteiro entre 1 e 50
# RERANK_TOP_N  : inteiro entre 1 e 100
# CHUNK_SIZE    : inteiro entre 64 e 4096
# CHUNK_OVERLAP : inteiro entre 0 e 512
# Variáveis com $ no valor: usar $$ no arquivo .env.prod para escape do docker compose
# ─────────────────────────────────────────────────────────────────────────
